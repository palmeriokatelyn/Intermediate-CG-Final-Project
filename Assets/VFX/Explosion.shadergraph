{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "92bef62d6a234e35927a985f38d34d71",
    "m_Title": "FireColour",
    "m_Content": "Functionally the same as the DarkColour layer done up top, aside from one key difference of splitting the R value from the UV node instead of the G one. This allows this layer to be on top of the other one and take priority, as well as emitting a stronger effect on the explosion.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
