{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "4b088d81770c4cebb1ea0312f522c079",
    "m_Title": "UV Splitting",
    "m_Content": "I used the UV node here to adjust the texture in order to achieve the dissolving explosion effect over time. This section samples the G value of the UV using the Split node, and is then multiplied into a subtract node to achieve this effect.",
