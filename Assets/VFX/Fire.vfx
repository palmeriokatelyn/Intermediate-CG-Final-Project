  stickyNoteInfos:
  - title: Fire
    position:
      serializedVersion: 2
      x: 1006
      y: -1546
      width: 163
      height: 100
    contents: 'These 3 VFX effects are identical except for the texture used, so
      I will just annotate this one. '
    theme: Classic
    textSize: Small
  - title: Spawn system
    position:
      serializedVersion: 2
      x: 678
      y: -1238
      width: 178
      height: 100
    contents: 'Spawns a single particle at runtime. I wanted one big piece of fire
      to emphasize the size of it. It looks...okay enough.

'
    theme: Classic
    textSize: Small
  - title: Initialize Particle
    position:
      serializedVersion: 2
      x: 678
      y: -762
      width: 171
      height: 200
    contents: 'Initializing the base particle values. Lifetime is set to 500, because
      I want the fires to last. Angle is rotated in here because Unity wasn''t letting
      me rotate the actual VFX object, and since the fire texture is a png it looked
      awkward from a side view.

'
    theme: Classic
    textSize: Small
  - title: Title
    position:
      serializedVersion: 2
      x: 1364
      y: -124
      width: 231
      height: 100
    contents: type something here
    theme: Classic
    textSize: Small
  categories: []
  uiBounds:
    serializedVersion: 2
    x: 678
    y: -1546
    width: 650
    height: 1899
