{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "9dee01462d2f4657835cbf8abcc1ca57",
    "m_Title": "Adding Voronoi",
    "m_Content": "The Voronoi added here are what gives the fire effect it's wobbly, dissolving look. Multiplying a speed float and time alongside the voronoi and then multiplying it with the sampled texture achieves this effect.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
